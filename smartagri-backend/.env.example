# MongoDB Configuration
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/database?retryWrites=true&w=majority&appName=SmartAgri
MONGODB_DB=smartagri_db

# Google Gemini API Configuration
# Get your API key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OpenWeather API Configuration
# Get your API key from https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Groq API Configuration
# Get your API key from https://console.groq.com/
GROQ_API_KEY=your_groq_api_key_here

# SMTP Configuration for Email Notifications
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Farm Advisory Service URL
FARM_ADVISORY_URL=http://localhost:5000

# JWT Configuration
JWT_SECRET=your_secure_jwt_secret_key_here
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440
